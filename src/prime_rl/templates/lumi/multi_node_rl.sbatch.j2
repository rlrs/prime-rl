#!/bin/bash

#SBATCH --job-name={{ job_name }}
#SBATCH --nodes={{ num_train_nodes + num_infer_nodes + num_judge_nodes }}
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=56
#SBATCH --gpus-per-node={{ gpus_per_node }}
#SBATCH --partition={{ partition }}
{%- if account %}
#SBATCH --account={{ account }}
{%- endif %}
{%- if time %}
#SBATCH --time={{ time }}
{%- endif %}
{%- if nodelist %}
#SBATCH --nodelist={{ nodelist }}
{%- endif %}
{%- if exclude %}
#SBATCH --exclude={{ exclude }}
{%- endif %}
#SBATCH --mem=0
#SBATCH --exclusive=user
#SBATCH --hint=nomultithread
#SBATCH --output={{ output_dir }}/job_%j.log
#SBATCH --error={{ output_dir }}/job_%j.err

set -euo pipefail

export NUM_TRAIN_NODES={{ num_train_nodes }}
export NUM_INFER_NODES={{ num_infer_nodes }}
export NUM_JUDGE_NODES={{ num_judge_nodes }}
export NODES_PER_INFER_REPLICA={{ nodes_per_infer_replica }}
export NUM_INFER_REPLICAS={{ num_infer_replicas }}
export GPUS_PER_NODE={{ gpus_per_node }}
export ROUTER_PORT={{ router_port }}
export BACKEND_PORT={{ backend_port }}
export INFERENCE_TP={{ inference_tp }}
export INFERENCE_ENABLE_EXPERT_PARALLEL={{ "1" if inference_enable_expert_parallel else "0" }}
export INFERENCE_DATA_PARALLEL_RPC_PORT={{ inference_data_parallel_rpc_port }}
export INFERENCE_DP_LOCAL=$((GPUS_PER_NODE / INFERENCE_TP))

export JUDGE_ENABLED={{ "1" if judge_enabled else "0" }}
export JUDGE_TP={{ judge_tp }}
export JUDGE_ENABLE_EXPERT_PARALLEL={{ "1" if judge_enable_expert_parallel else "0" }}
export JUDGE_DATA_PARALLEL_RPC_PORT={{ judge_data_parallel_rpc_port }}
export JUDGE_PORT={{ judge_port }}
export JUDGE_DP_LOCAL=$((GPUS_PER_NODE / JUDGE_TP))

export USE_DISTRIBUTED_EP=0
if [ "$INFERENCE_ENABLE_EXPERT_PARALLEL" -eq 1 ] && [ "$NODES_PER_INFER_REPLICA" -gt 1 ]; then
    USE_DISTRIBUTED_EP=1
fi

export JUDGE_USE_DISTRIBUTED_EP=0
if [ "$JUDGE_ENABLED" -eq 1 ] && [ "$JUDGE_ENABLE_EXPERT_PARALLEL" -eq 1 ] && [ "$NUM_JUDGE_NODES" -gt 1 ]; then
    JUDGE_USE_DISTRIBUTED_EP=1
fi

export PROJECT_DIR={{ project_dir }}
export CONFIG_DIR={{ config_dir }}
export OUTPUT_DIR={{ output_dir }}
export ORCHESTRATOR_OUTPUT_DIR={{ orchestrator_output_dir }}
mkdir -p "$OUTPUT_DIR"/slurm

rm -rf "$OUTPUT_DIR"/run_*/rollouts
rm -rf "$OUTPUT_DIR"/run_*/broadcasts
rm -rf "$OUTPUT_DIR"/rollouts

BASE_DIR=/pfs/lustref1/appl/local/laifs
LAIFS_APPL_DIR=/appl/local/laifs
SIF=${SIF:-$BASE_DIR/containers/lumi-multitorch-u24r64f21m43t29-20260216_093549/lumi-multitorch-full-u24r64f21m43t29-20260216_093549.sif}
OVERLAY_DIR=${OVERLAY_DIR:-$PROJECT_DIR/overlay_vllm_rocm72_main}
OVERLAY_ENV_NAME=${OVERLAY_ENV_NAME:-vllm-min}
FLASH_PROJECT_ROOT=${FLASH_PROJECT_ROOT:-/flash/project_465002183}
FLASH_CACHE_ROOT=${FLASH_CACHE_ROOT:-$FLASH_PROJECT_ROOT/andreas/.cache}
HF_HOME=${HF_HOME:-$FLASH_CACHE_ROOT/huggingface}
UV_CACHE_DIR=${UV_CACHE_DIR:-$FLASH_CACHE_ROOT/uv}
XDG_CACHE_HOME=${XDG_CACHE_HOME:-$FLASH_CACHE_ROOT}
WANDB_CACHE_DIR=${WANDB_CACHE_DIR:-$FLASH_CACHE_ROOT/wandb}
WANDB_CONFIG_DIR=${WANDB_CONFIG_DIR:-$FLASH_PROJECT_ROOT/.config/wandb}
export OVERLAY_ENV_NAME
export HF_HOME UV_CACHE_DIR XDG_CACHE_HOME WANDB_CACHE_DIR WANDB_CONFIG_DIR

if [[ ! -f "$SIF" ]]; then
    echo "FATAL: SIF not found: $SIF" >&2
    exit 1
fi

if [[ ! -d "$OVERLAY_DIR/venv/$OVERLAY_ENV_NAME" ]]; then
    echo "FATAL: overlay env not found: $OVERLAY_DIR/venv/$OVERLAY_ENV_NAME" >&2
    echo "Build it with: ./scripts/build_overlay_minimal.sh" >&2
    exit 1
fi

mkdir -p "$HF_HOME" "$UV_CACHE_DIR" "$XDG_CACHE_HOME" "$WANDB_CACHE_DIR" "$WANDB_CONFIG_DIR"

HOSTNAMES=( $(scontrol show hostnames "$SLURM_JOB_NODELIST") )
INFER_HOSTS=( ${HOSTNAMES[@]:0:$NUM_INFER_NODES} )
JUDGE_HOSTS=( ${HOSTNAMES[@]:$NUM_INFER_NODES:$NUM_JUDGE_NODES} )
TRAIN_HOSTS=( ${HOSTNAMES[@]:$((NUM_INFER_NODES + NUM_JUDGE_NODES)):$NUM_TRAIN_NODES} )
export HOSTNAMES_STR="${HOSTNAMES[*]}"
export INFER_HEAD_HOST="${INFER_HOSTS[0]}"
if [ "$NUM_JUDGE_NODES" -gt 0 ]; then
    export JUDGE_HEAD_HOST="${JUDGE_HOSTS[0]}"
else
    export JUDGE_HEAD_HOST=""
fi

INFER_URLS=""
ADMIN_URLS=""
ALL_ROUTER_ARGS=""
for ((r=0; r<NUM_INFER_REPLICAS; r++)); do
    head_idx=$((r * NODES_PER_INFER_REPLICA))
    router_host="${INFER_HOSTS[$head_idx]}"
    INFER_URLS="${INFER_URLS:+$INFER_URLS }http://${router_host}:${ROUTER_PORT}/v1"

    REPLICA_ROUTER_ARGS=""
    for ((n=0; n<NODES_PER_INFER_REPLICA; n++)); do
        node_idx=$((head_idx + n))
        host="${INFER_HOSTS[$node_idx]}"
        ADMIN_URLS="${ADMIN_URLS:+$ADMIN_URLS }http://${host}:${BACKEND_PORT}/v1"
        REPLICA_ROUTER_ARGS="$REPLICA_ROUTER_ARGS http://${host}:${BACKEND_PORT}"
    done
    ALL_ROUTER_ARGS="${ALL_ROUTER_ARGS:+$ALL_ROUTER_ARGS|}$REPLICA_ROUTER_ARGS"
done
export INFER_URLS
export ADMIN_URLS
export ALL_ROUTER_ARGS

JUDGE_BASE_URL=""
if [ "$JUDGE_ENABLED" -eq 1 ]; then
    if [ "$JUDGE_USE_DISTRIBUTED_EP" -eq 1 ]; then
        JUDGE_BASE_URL="http://${JUDGE_HEAD_HOST}:${JUDGE_PORT}/v1"
    else
        for host in "${JUDGE_HOSTS[@]}"; do
            if [ -z "$JUDGE_BASE_URL" ]; then
                JUDGE_BASE_URL="http://$host:${JUDGE_PORT}/v1"
            else
                JUDGE_BASE_URL="$JUDGE_BASE_URL,http://$host:${JUDGE_PORT}/v1"
            fi
        done
    fi
fi
export JUDGE_BASE_URL

export MASTER_ADDR="${HOSTNAMES[$((NUM_INFER_NODES + NUM_JUDGE_NODES))]}"
export MASTER_PORT=29500

echo "HOSTNAMES=${HOSTNAMES[*]}"
echo "TRAIN_HOSTS=${TRAIN_HOSTS[*]}"
echo "INFER_HOSTS=${INFER_HOSTS[*]}"
echo "JUDGE_HOSTS=${JUDGE_HOSTS[*]}"
echo "INFER_URLS=${INFER_URLS}"
echo "ADMIN_URLS=${ADMIN_URLS}"
echo "JUDGE_BASE_URL=${JUDGE_BASE_URL}"
echo "USE_DISTRIBUTED_EP=${USE_DISTRIBUTED_EP}"
echo "JUDGE_USE_DISTRIBUTED_EP=${JUDGE_USE_DISTRIBUTED_EP}"
echo "MASTER_ADDR=${MASTER_ADDR}"
echo "MASTER_PORT=${MASTER_PORT}"

{% if pre_run_command %}
cd "$PROJECT_DIR"
[ -f .env ] && source .env
{{ pre_run_command }}
{% endif %}

SING_BIND_ARGS=(
    -B "$BASE_DIR:$LAIFS_APPL_DIR"
    -B "$OVERLAY_DIR:/overlay"
    -B "$PROJECT_DIR:/workdir"
)
if [[ -f "$OVERLAY_DIR/overlay-runtime.binds" ]]; then
    while IFS= read -r bind; do
        [[ -n "$bind" ]] || continue
        SING_BIND_ARGS+=(-B "$bind")
    done < "$OVERLAY_DIR/overlay-runtime.binds"
fi
if [[ -d /flash ]]; then
    SING_BIND_ARGS+=(-B /flash:/flash)
fi
if [[ -e "$FLASH_PROJECT_ROOT" ]]; then
    FLASH_PROJECT_TARGET="$(readlink -f "$FLASH_PROJECT_ROOT" || true)"
    if [[ -n "$FLASH_PROJECT_TARGET" && -d "$FLASH_PROJECT_TARGET" ]]; then
        SING_BIND_ARGS+=(-B "$FLASH_PROJECT_TARGET:$FLASH_PROJECT_TARGET")
    elif [[ -d "$FLASH_PROJECT_ROOT" ]]; then
        SING_BIND_ARGS+=(-B "$FLASH_PROJECT_ROOT:$FLASH_PROJECT_ROOT")
    fi
fi
if [[ -d /scratch ]]; then
    SING_BIND_ARGS+=(-B /scratch:/scratch)
fi

srun singularity exec --rocm "${SING_BIND_ARGS[@]}" "$SIF" bash -c '
set -euo pipefail

source /overlay/venv/"$OVERLAY_ENV_NAME"/bin/activate
OVERLAY_SITE=/overlay/venv/"$OVERLAY_ENV_NAME"/lib/python3.12/site-packages
export PYTHONPATH=/workdir/src:"${OVERLAY_SITE}"${PYTHONPATH:+:${PYTHONPATH}}
export UV_NO_SYNC=1

if [[ -f /overlay/overlay-runtime.env ]]; then
    source /overlay/overlay-runtime.env
fi

if [[ -n "${ROCR_VISIBLE_DEVICES:-}" && -z "${HIP_VISIBLE_DEVICES:-}" ]]; then
    export HIP_VISIBLE_DEVICES="${ROCR_VISIBLE_DEVICES}"
fi
if [[ -n "${HIP_VISIBLE_DEVICES:-}" && -z "${ROCR_VISIBLE_DEVICES:-}" ]]; then
    export ROCR_VISIBLE_DEVICES="${HIP_VISIBLE_DEVICES}"
fi
if [[ -n "${SSL_CERT_FILE:-}" && ! -f "${SSL_CERT_FILE}" ]]; then
    unset SSL_CERT_FILE
fi
if [[ -n "${SSL_CERT_DIR:-}" && ! -d "${SSL_CERT_DIR}" ]]; then
    unset SSL_CERT_DIR
fi

export HF_HOME
export UV_CACHE_DIR
export XDG_CACHE_HOME
export WANDB_CACHE_DIR
export WANDB_CONFIG_DIR
export CUDA_DEVICE_ORDER=PCI_BUS_ID
export PYTHONUNBUFFERED=1
export OMP_NUM_THREADS=1

cd /workdir
[ -f .env ] && source .env

ulimit -n 65536
export GIT_LFS_SKIP_SMUDGE=1

if command -v ibv_devinfo >/dev/null 2>&1; then
    IB_HCA=$(ibv_devinfo | sed -n -e "/hca_id/p" -e "/link_layer:/p" | grep -B1 InfiniBand | grep hca_id | sed -e "s/^hca_id://g" | tr -d "[[:blank:]]" | paste -sd,)
    if [[ -n "$IB_HCA" ]]; then
        export NCCL_IB_HCA="$IB_HCA"
    fi
fi

if [ "$SLURM_PROCID" -lt "$NUM_INFER_NODES" ]; then
    export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:False
    export VLLM_WORKER_MULTIPROC_METHOD=spawn

    INFER_NODE_RANK=$SLURM_PROCID
    LOCAL_IP=$(hostname -I | awk "{print \$1}")
    REPLICA_IDX=$((INFER_NODE_RANK / NODES_PER_INFER_REPLICA))
    RANK_IN_REPLICA=$((INFER_NODE_RANK % NODES_PER_INFER_REPLICA))

    echo "INFER_NODE_RANK=$INFER_NODE_RANK REPLICA=$REPLICA_IDX RANK_IN_REPLICA=$RANK_IN_REPLICA LOCAL_IP=$LOCAL_IP" \
        | tee "$OUTPUT_DIR"/slurm/latest_infer_node_rank_"${INFER_NODE_RANK}".log \
              "$OUTPUT_DIR"/slurm/job_"${SLURM_JOB_ID}"_infer_node_rank_"${INFER_NODE_RANK}".log

    if [ "$RANK_IN_REPLICA" -eq 0 ]; then
        ROUTER_LOG="$OUTPUT_DIR"/slurm/latest_router_replica_"${REPLICA_IDX}".log
        echo "Starting vllm-router on $LOCAL_IP:$ROUTER_PORT for replica $REPLICA_IDX" | tee "$ROUTER_LOG"
        REPLICA_ROUTER_ARGS=$(echo "$ALL_ROUTER_ARGS" | cut -d"|" -f$((REPLICA_IDX + 1)))

        vllm-router \
            --policy round_robin \
            --worker-urls $REPLICA_ROUTER_ARGS \
            --host 0.0.0.0 \
            --port "$ROUTER_PORT" \
            --worker-startup-timeout-secs 1200 \
            --log-level debug \
            >> "$ROUTER_LOG" 2>&1 &
    fi

    if [ "$USE_DISTRIBUTED_EP" -eq 1 ]; then
        read -ra HOSTNAMES <<< "$HOSTNAMES_STR"
        REPLICA_HEAD_HOST="${HOSTNAMES[$((REPLICA_IDX * NODES_PER_INFER_REPLICA))]}"
        INFER_DP_START_RANK=$((RANK_IN_REPLICA * INFERENCE_DP_LOCAL))

        if [ "$RANK_IN_REPLICA" -eq 0 ]; then
            VLLM_EXTRA="{\"data_parallel_address\": \"$LOCAL_IP\"}"
        else
            VLLM_EXTRA="{\"data_parallel_address\": \"$REPLICA_HEAD_HOST\", \"data_parallel_start_rank\": $INFER_DP_START_RANK}"
        fi

        python -m prime_rl.inference.server \
            @ "$CONFIG_DIR"/inference.toml \
            --server.host 0.0.0.0 \
            --server.port "$BACKEND_PORT" \
            --data-parallel-rpc-port "$INFERENCE_DATA_PARALLEL_RPC_PORT" \
            --vllm-extra "$VLLM_EXTRA" \
            2>&1 | tee -a "$OUTPUT_DIR"/slurm/latest_infer_node_rank_"${INFER_NODE_RANK}".log \
                          "$OUTPUT_DIR"/slurm/job_"${SLURM_JOB_ID}"_infer_node_rank_"${INFER_NODE_RANK}".log
    else
        python -m prime_rl.inference.server \
            @ "$CONFIG_DIR"/inference.toml \
            --server.host 0.0.0.0 \
            --server.port "$BACKEND_PORT" \
            2>&1 | tee -a "$OUTPUT_DIR"/slurm/latest_infer_node_rank_"${INFER_NODE_RANK}".log \
                          "$OUTPUT_DIR"/slurm/job_"${SLURM_JOB_ID}"_infer_node_rank_"${INFER_NODE_RANK}".log
    fi
elif [ "$SLURM_PROCID" -lt $((NUM_INFER_NODES + NUM_JUDGE_NODES)) ]; then
    export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:False
    export VLLM_WORKER_MULTIPROC_METHOD=spawn

    JUDGE_NODE_RANK=$((SLURM_PROCID - NUM_INFER_NODES))
    if [ "$JUDGE_ENABLED" -ne 1 ]; then
        echo "judge nodes allocated but JUDGE_ENABLED != 1" >&2
        exit 1
    fi

    if [ "$JUDGE_USE_DISTRIBUTED_EP" -eq 1 ]; then
        JUDGE_DP_START_RANK=$((JUDGE_NODE_RANK * JUDGE_DP_LOCAL))
        if [ "$JUDGE_NODE_RANK" -eq 0 ]; then
            python -m prime_rl.inference.server \
                @ "$CONFIG_DIR"/judge_inference.toml \
                --data-parallel-address "$JUDGE_HEAD_HOST" \
                --data-parallel-rpc-port "$JUDGE_DATA_PARALLEL_RPC_PORT" \
                2>&1 | tee "$OUTPUT_DIR"/slurm/latest_judge_node_rank_"${JUDGE_NODE_RANK}".log \
                              "$OUTPUT_DIR"/slurm/job_"${SLURM_JOB_ID}"_judge_node_rank_"${JUDGE_NODE_RANK}".log
        else
            python -m prime_rl.inference.server \
                @ "$CONFIG_DIR"/judge_inference.toml \
                --data-parallel-start-rank "$JUDGE_DP_START_RANK" \
                --data-parallel-address "$JUDGE_HEAD_HOST" \
                --data-parallel-rpc-port "$JUDGE_DATA_PARALLEL_RPC_PORT" \
                --headless \
                2>&1 | tee "$OUTPUT_DIR"/slurm/latest_judge_node_rank_"${JUDGE_NODE_RANK}".log \
                              "$OUTPUT_DIR"/slurm/job_"${SLURM_JOB_ID}"_judge_node_rank_"${JUDGE_NODE_RANK}".log
        fi
    else
        python -m prime_rl.inference.server \
            @ "$CONFIG_DIR"/judge_inference.toml \
            2>&1 | tee "$OUTPUT_DIR"/slurm/latest_judge_node_rank_"${JUDGE_NODE_RANK}".log \
                          "$OUTPUT_DIR"/slurm/job_"${SLURM_JOB_ID}"_judge_node_rank_"${JUDGE_NODE_RANK}".log
    fi
else
    TRAIN_NODE_RANK=$((SLURM_PROCID - NUM_INFER_NODES - NUM_JUDGE_NODES))

    if [ "$TRAIN_NODE_RANK" -eq 0 ]; then
        ORCHESTRATOR_ARGS="@ $CONFIG_DIR/orchestrator.toml"
        ORCHESTRATOR_ARGS="$ORCHESTRATOR_ARGS --client.base-url $INFER_URLS"
        ORCHESTRATOR_ARGS="$ORCHESTRATOR_ARGS --client.admin-base-url $ADMIN_URLS"
        {% if use_nccl_broadcast %}ORCHESTRATOR_ARGS="$ORCHESTRATOR_ARGS --weight_broadcast.host $MASTER_ADDR"
        {% endif %}{% if wandb_shared %}WANDB_SHARED_LABEL=orchestrator {% endif %}python -m prime_rl.orchestrator.orchestrator $ORCHESTRATOR_ARGS \
            2>&1 | tee "$OUTPUT_DIR"/slurm/latest_orchestrator.log "$OUTPUT_DIR"/slurm/job_"${SLURM_JOB_ID}"_orchestrator.log &
    fi

    export HF_HUB_OFFLINE=1
    export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

    echo "$HOSTNAMES_STR" | tee "$OUTPUT_DIR"/slurm/latest_train_node_rank_"${TRAIN_NODE_RANK}".log

    {% if wandb_shared %}WANDB_SHARED_LABEL=trainer {% endif %}python -m torch.distributed.run \
        --nnodes="$NUM_TRAIN_NODES" \
        --nproc-per-node="$GPUS_PER_NODE" \
        --node-rank="$TRAIN_NODE_RANK" \
        --rdzv-endpoint="$MASTER_ADDR":"$MASTER_PORT" \
        --rdzv-id=job_"$SLURM_JOB_ID" \
        --log-dir="$OUTPUT_DIR"/torchrun \
        --tee=3 \
        --redirects=3 \
        --local-ranks-filter="$(seq -s, 0 $((GPUS_PER_NODE - 1)))" \
        -m prime_rl.trainer.rl.train \
        @ "$CONFIG_DIR"/trainer.toml \
        2>&1 | tee -a "$OUTPUT_DIR"/slurm/latest_train_node_rank_"${TRAIN_NODE_RANK}".log \
                      "$OUTPUT_DIR"/slurm/job_"${SLURM_JOB_ID}"_train_node_rank_"${TRAIN_NODE_RANK}".log
fi
'
